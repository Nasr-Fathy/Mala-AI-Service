# ─── Application ───────────────────────────────────────────────
APP_NAME=Financial AI Service
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=development          # development | staging | production

# ─── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8090
WORKERS=1

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["*"]

# ─── LLM Provider ────────────────────────────────────────────
# Options: vertex | openai | google_studio
LLM_PROVIDER=vertex

# ─── Vertex AI ───────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-1.5-pro-002
VERTEX_MAX_OUTPUT_TOKENS=8192
VERTEX_TEMPERATURE=0.1

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_OUTPUT_TOKENS=8192
OPENAI_TEMPERATURE=0.1

# ─── Google AI Studio (Gemini via API key) ───────────────────
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-1.5-pro
GOOGLE_AI_MAX_OUTPUT_TOKENS=8192
GOOGLE_AI_TEMPERATURE=0.1

# ─── LLM Retry ───────────────────────────────────────────────
LLM_MAX_RETRIES=5
LLM_BASE_DELAY=1.0
LLM_MAX_DELAY=60.0
LLM_JITTER_FACTOR=0.5

# ─── Category Mapper ─────────────────────────────────────────
CATEGORY_MAPPER_CSV_PATH=
CATEGORY_MAPPER_REMOTE_URL=
CATEGORY_MAPPER_USE_REMOTE=false
CATEGORY_MAPPER_CACHE_TTL=3600

# ─── LangSmith Tracing ────────────────────────────────────────
# Leave LANGSMITH_API_KEY empty to disable tracing (zero overhead).
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=financial-ai-service
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ─── API ──────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
MAX_UPLOAD_SIZE_MB=50
