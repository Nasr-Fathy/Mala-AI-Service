{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pass 2: Period Detection & Segmentation Output",
  "description": "Schema for validating Pass 2 (Segmentation) LLM output",
  "type": "object",
  "required": ["statements"],
  "properties": {
    "statements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["statement_type", "start_page", "end_page"],
        "properties": {
          "statement_type": {
            "type": "string",
            "enum": [
              "BALANCE_SHEET",
              "INCOME_STATEMENT",
              "CASH_FLOW",
              "CHANGES_IN_EQUITY",
              "COMPREHENSIVE_INCOME",
              "NOTES"
            ]
          },
          "title_en": {
            "type": ["string", "null"]
          },
          "title_ar": {
            "type": ["string", "null"]
          },
          "start_page": {
            "type": "integer",
            "minimum": 1
          },
          "end_page": {
            "type": "integer",
            "minimum": 1
          },
          "table_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "index": {
                  "type": "integer",
                  "minimum": 0
                },
                "fiscal_year": {
                  "type": "integer",
                  "minimum": 1900,
                  "maximum": 2100
                },
                "period_type": {
                  "type": "string",
                  "enum": ["ANNUAL", "QUARTERLY", "SEMI_ANNUAL", "MONTHLY"]
                },
                "header_text": {
                  "type": ["string", "null"]
                }
              }
            }
          }
        }
      }
    },
    "notes_section": {
      "type": ["object", "null"],
      "properties": {
        "start_page": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "end_page": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "table_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "segmentation_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
