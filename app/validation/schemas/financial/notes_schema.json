{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pass 4: Notes Extraction Output",
  "description": "Schema for validating Pass 4 (Notes) LLM output",
  "type": "object",
  "required": ["notes"],
  "properties": {
    "notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["note_number", "title_en"],
        "properties": {
          "note_number": {
            "type": "string",
            "minLength": 1
          },
          "title_en": {
            "type": "string",
            "minLength": 1
          },
          "title_ar": {
            "type": ["string", "null"]
          },
          "description": {
            "type": ["string", "null"]
          },
          "content_type": {
            "type": "string",
            "enum": ["TEXT", "TABLE", "MIXED"]
          },
          "has_table": {
            "type": "boolean"
          },
          "table_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "page": {
            "type": ["integer", "null"],
            "minimum": 1
          },
          "related_line_items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "key_disclosures": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sub_notes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["note_number", "title_en"],
              "properties": {
                "note_number": {
                  "type": "string"
                },
                "title_en": {
                  "type": "string"
                },
                "title_ar": {
                  "type": ["string", "null"]
                },
                "description": {
                  "type": ["string", "null"]
                }
              }
            }
          },
          "table_data": {
            "type": ["object", "null"],
            "properties": {
              "headers": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "rows": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {
                    "type": ["string", "number", "null"]
                  }
                }
              }
            }
          }
        }
      }
    },
    "accounting_policies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "policy_name": {
            "type": "string"
          },
          "note_reference": {
            "type": ["string", "null"]
          },
          "summary": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "contingencies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "note_reference": {
            "type": ["string", "null"]
          },
          "description": {
            "type": ["string", "null"]
          },
          "amount": {
            "type": ["number", "null"]
          },
          "likelihood": {
            "type": ["string", "null"],
            "enum": ["Probable", "Possible", "Remote", null]
          }
        }
      }
    },
    "related_parties": {
      "type": ["object", "null"],
      "properties": {
        "note_reference": {
          "type": ["string", "null"]
        },
        "transactions_disclosed": {
          "type": "boolean"
        },
        "parties_identified": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
